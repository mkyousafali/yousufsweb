# ============================================================
# .env.example — Environment Variable Template
# Copy this file to .env and fill in your values.
# Run: node INITIALIZER_SCRIPT.js for guided setup.
# NEVER commit your real .env file to version control.
# ============================================================

# Supabase Project URL (found in Project Settings > API)
PUBLIC_SUPABASE_URL=

# Supabase Anon/Public Key (safe for client-side use with RLS)
PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (SERVER-SIDE ONLY — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Initial Admin Account Credentials (used in INITIALIZER_SCRIPT.js only)
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=
